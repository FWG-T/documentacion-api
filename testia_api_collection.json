  "item": [
    {
      "name": "Gestión de Contratista Empresa",
      "description": "Endpoints para registrar y consultar contratistas tipo Empresa.\n\ncontractorTypeId: 1 (Empresa)\n\nDocumentos:\n- 16: F30 (Total pagos)\n- 17: F30-1 (Pagos individuales)\n- 18: Carpeta Tributaria\n\nTipos de servicio:\n- 1: Monitoreo\n- 2: Revisión única\n\nDocumentación completa: https://www.testia.cl/api-reference#tag/Gestion-de-Contratista-Empresa",
      "item": [
        {
          "name": "Crear Contratista Empresa",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "apikey",
                "value": "{{api_key}}",
                "description": "API Key de autenticación"
              }
            ],
            "url": {
              "raw": "{{base_url}}/request/contractor",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "request",
                "contractor"
              ],
              "variable": [],
              "query": []
            },
            "description": "Registra un contratista tipo Empresa. Usar contractorTypeId: 1.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "contractor",
                  "type": "text",
                  "value": "{\n  \"contractorTypeId\": 1,\n  \"rut\": \"{{rut_contratista_empresa}}\",\n  \"businessName\": \"{{business_name}}\",\n  \"serviceTypeId\": \"1\",\n  \"reviewStartDate\": \"2026-06-17\",\n  \"reviewEndDate\": \"2027-06-16\",\n  \"reviewCompaniesId\": []\n}",
